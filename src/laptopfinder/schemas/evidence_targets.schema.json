{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laptopfinder.local/schemas/evidence_targets.schema.json",
  "title": "Evidence-Derived Hardware Targets",
  "description": "Provisional hardware target ranges inferred from aggregated telemetry evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "system_memory_gb",
    "vram_gb",
    "storage_gb",
    "platform_tradeoffs",
    "confidence_notes",
    "cpu_tier",
    "platform_classes"
  ],
  "properties": {
    "system_memory_gb": {
      "$ref": "#/$defs/range_triplet"
    },
    "vram_gb": {
      "$ref": "#/$defs/range_triplet"
    },
    "storage_gb": {
      "$ref": "#/$defs/storage_range"
    },
    "platform_tradeoffs": {
      "type": "array",
      "description": "Short, soft-language tradeoff notes about Apple unified memory vs discrete GPU platforms and related buying considerations.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 10
    },
    "confidence_notes": {
      "type": ["string", "null"],
      "description": "Brief note summarizing what evidence is strong, thin, noisy, or provisional."
    },
    "cpu_tier": {
      "type": "object",
      "description": "Recommended CPU tier derived from observed load shape.",
      "additionalProperties": false,
      "required": ["core_count_min", "single_thread_priority", "rationale"],
      "properties": {
        "core_count_min":        { "type": "integer", "minimum": 1 },
        "single_thread_priority": { "type": "boolean" },
        "sustained_load":        { "type": ["boolean", "null"] },
        "rationale":             { "type": "string", "minLength": 1 }
      }
    },
    "platform_classes": {
      "type": "array",
      "description": "Vendor-neutral GPU/compute class recommendations. One entry per vendor.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["vendor", "unified_or_discrete", "memory_target_gb", "throughput_target_tok_s", "caveats"],
        "properties": {
          "vendor":                   { "enum": ["Apple", "AMD", "NVIDIA"] },
          "unified_or_discrete":      { "enum": ["unified", "discrete"] },
          "memory_target_gb":         { "type": "integer", "minimum": 0 },
          "throughput_target_tok_s":  { "type": ["number", "null"] },
          "caveats":                  { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "range_triplet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "recommended", "stretch"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 0
        },
        "recommended": {
          "type": "integer",
          "minimum": 0
        },
        "stretch": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "storage_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "recommended"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 0
        },
        "recommended": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}

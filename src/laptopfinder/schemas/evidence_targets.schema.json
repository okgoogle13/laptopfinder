{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laptopfinder.local/schemas/evidence_targets.schema.json",
  "title": "Evidence-Derived Hardware Targets",
  "description": "Provisional hardware target ranges inferred from aggregated telemetry evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "system_memory_gb",
    "vram_gb",
    "storage_gb",
    "platform_tradeoffs",
    "confidence_notes"
  ],
  "properties": {
    "system_memory_gb": {
      "$ref": "#/$defs/range_triplet"
    },
    "vram_gb": {
      "$ref": "#/$defs/range_triplet"
    },
    "storage_gb": {
      "$ref": "#/$defs/storage_range"
    },
    "platform_tradeoffs": {
      "type": "array",
      "description": "Short, soft-language tradeoff notes about Apple unified memory vs discrete GPU platforms and related buying considerations.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 10
    },
    "confidence_notes": {
      "type": ["string", "null"],
      "description": "Brief note summarizing what evidence is strong, thin, noisy, or provisional."
    }
  },
  "$defs": {
    "range_triplet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "recommended", "stretch"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 0
        },
        "recommended": {
          "type": "integer",
          "minimum": 0
        },
        "stretch": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "storage_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "recommended"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 0
        },
        "recommended": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}

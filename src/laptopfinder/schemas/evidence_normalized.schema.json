{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laptopfinder.local/schemas/evidence_normalized.schema.json",
  "title": "Normalized Evidence Record",
  "description": "Normalized macOS telemetry evidence extracted from a single raw artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_timestamp",
    "source_file",
    "scenario_label",
    "source_kind",
    "collection_notes",
    "data_confidence",
    "observed_telemetry",
    "active_processes",
    "uncertainty_flags"
  ],
  "properties": {
    "event_timestamp": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp if present in the artifact or provided metadata."
    },
    "source_file": {
      "type": ["string", "null"],
      "minLength": 1,
      "description": "Filename of the raw evidence artifact, if known."
    },
    "scenario_label": {
      "type": ["string", "null"],
      "minLength": 1,
      "description": "Short workload label such as idle_browser, antigravity_gemini_coding, or browser_plus_local_llm."
    },
    "source_kind": {
      "type": "string",
      "enum": ["terminal_log", "screenshot_ocr", "mixed"],
      "description": "Primary origin of the raw evidence artifact."
    },
    "collection_notes": {
      "type": ["string", "null"],
      "description": "Short human-supplied context about the capture session."
    },
    "data_confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Overall confidence in the record based on completeness and ambiguity."
    },
    "observed_telemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory_pressure_state",
        "physical_memory_gb",
        "app_memory_gb",
        "wired_memory_gb",
        "compressed_memory_gb",
        "cached_files_gb",
        "swap_used_gb"
      ],
      "properties": {
        "memory_pressure_state": {
          "type": "string",
          "enum": ["Normal", "Warning", "Critical", "Unknown"],
          "description": "Observed or conservatively inferred macOS memory pressure state."
        },
        "physical_memory_gb": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Installed physical RAM in GB."
        },
        "app_memory_gb": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Approximate app or process memory in GB, if supported by the artifact."
        },
        "wired_memory_gb": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Wired memory in GB."
        },
        "compressed_memory_gb": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Compressed memory in GB."
        },
        "cached_files_gb": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Cached files or file cache in GB."
        },
        "swap_used_gb": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Current swap used in GB."
        },
        "cpu_telemetry": {
          "type": ["object", "null"],
          "description": "CPU load shape derived from top -l output.",
          "properties": {
            "cpu_user_pct":    { "type": ["number", "null"], "description": "User-space CPU % across all cores." },
            "cpu_sys_pct":     { "type": ["number", "null"], "description": "Kernel-space CPU % across all cores." },
            "cpu_idle_pct":    { "type": ["number", "null"], "description": "Idle CPU % across all cores." },
            "cpu_cores_active": {
              "type": ["number", "null"],
              "description": "Derived: (100 - idle_pct) * logical_core_count / 100. Default 4 cores for 2017 iMac."
            },
            "load_pattern": {
              "type": ["string", "null"],
              "enum": ["spiky", "sustained", "idle", null],
              "description": "Characterisation of load shape over the capture window."
            }
          }
        },
        "gpu_telemetry": {
          "type": ["object", "null"],
          "description": "GPU activity and thermal signals from powermetrics --samplers gpu_power,smc.",
          "properties": {
            "gpu_residency_pct": { "type": ["number", "null"], "description": "GPU HW active residency %." },
            "gpu_freq_mhz":      { "type": ["number", "null"], "description": "GPU HW active frequency in MHz." },
            "gpu_power_mw":      { "type": ["number", "null"], "description": "GPU power draw in mW." },
            "cpu_die_temp_c":    { "type": ["number", "null"], "description": "CPU die temperature in Celsius (SMC)." },
            "fan_rpm":           { "type": ["number", "null"], "description": "Fan speed in RPM (SMC)." },
            "throttle_observed": { "type": ["boolean", "null"], "description": "True if thermal throttle or frequency cap detected." }
          }
        },
        "inference_telemetry": {
          "type": ["object", "null"],
          "description": "Local LLM inference economics. Populate only for llm_local_inference scenario.",
          "properties": {
            "model_name":               { "type": ["string", "null"] },
            "model_params_b":           { "type": ["number", "null"], "description": "Parameter count in billions." },
            "model_quant":              { "type": ["string", "null"], "description": "Quantisation string, e.g. Q4_K_M." },
            "context_length":           { "type": ["integer", "null"] },
            "tokens_per_sec_short_ctx": { "type": ["number", "null"], "description": "tok/s at short context (~512 tokens)." },
            "tokens_per_sec_long_ctx":  { "type": ["number", "null"], "description": "tok/s at long context (~4096 tokens)." },
            "model_peak_rss_gb":        { "type": ["number", "null"], "description": "Peak resident set size of inference process in GB." },
            "gpu_used_for_inference":   { "type": ["boolean", "null"], "description": "True if Metal or GPU backend was active." }
          }
        }
      }
    },
    "active_processes": {
      "type": "array",
      "description": "Short list of notable visible processes relevant to the workload.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "maxItems": 12,
      "uniqueItems": true
    },
    "uncertainty_flags": {
      "type": "array",
      "description": "Short machine-readable notes explaining ambiguity, conversion, OCR noise, or missing fields.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}

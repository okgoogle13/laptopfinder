# API Keys for Laptopfinder execution workflow

# AI Studio / Gemini API (used by AI Studio Runtime)
GEMINI_API_KEY="your_gemini_api_key_here"

# Anthropic API (used by Claude Code Audit runner)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Perplexity API (used by Perplexity Deep Research runner)
PERPLEXITY_API_KEY="your_perplexity_api_key_here"


# --- eBay Hunter (runners/ebay_hunter.py) ------------------------------------
# eBay Developer OAuth (client-credentials application token, Browse API)
EBAY_CLIENT_ID="your_ebay_app_client_id"
EBAY_CLIENT_SECRET="your_ebay_app_client_secret"
# NOTE: the hunter requests only the base Browse scope; it ignores EBAY_OAUTH_SCOPES
# (which may carry sell-API scopes your app isn't granted). Point the base URL at the
# environment your CLIENT_ID belongs to: sandbox creds -> api.sandbox.ebay.com.
# Sandbox has little/no real inventory; use PRODUCTION creds for a live AU market sweep.
EBAY_API_BASE_URL="https://api.ebay.com"
EBAY_MARKETPLACE_ID="EBAY_AU"
# EBAY_CATEGORY_IDS — removed; category ID is now owned by SRL (ebay_aspect_filter.category_id = 175672)
GEMINI_MODEL="gemini-3.5-flash"         # long-context triage + vision + enrichment

# Email alerts for new top-acquisition targets (stdlib smtplib).
# Gmail: create an App Password (Account > Security > App passwords), not your login.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"                         # 465 = SSL; any other port uses STARTTLS
SMTP_USER="you@gmail.com"
SMTP_PASSWORD="your_gmail_app_password"
ALERT_EMAIL_TO="you@gmail.com"          # defaults to SMTP_USER if unset
ALERT_EMAIL_FROM="you@gmail.com"        # defaults to SMTP_USER if unset

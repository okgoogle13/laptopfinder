{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vendor & Seller Risk Lens",
  "description": "Unified vendor risk database supporting both marketplace handles (eBay usernames) and retailer/OEM identities (domains/store codes).",
  "version": "1.0.0",
  "schema_definition": {
    "type": "array",
    "items": {
      "type": "object",
      "required": ["vendor_id", "vendor_type", "region", "risk_score", "flags"],
      "properties": {
        "vendor_id": {
          "type": "string",
          "description": "eBay username, retailer domain, or canonical store identifier."
        },
        "vendor_type": {
          "type": "string",
          "enum": [
            "MARKETPLACE_PRIVATE", "MARKETPLACE_STORE", "RETAILER", "OEM_OUTLET", "OEM_DIRECT",
            "Specialist retailer", "National retailer", "OEM outlet", "OEM direct"
          ]
        },
        "region": {
          "type": "string",
          "description": "Region code, e.g. AU, US, EU, GLOBAL."
        },
        "risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Normalized baseline vendor risk from 0 (pristine/official) to 10 (unverified/high-risk)."
        },
        "flags": {
          "type": "object",
          "properties": {
            "clearance_outlet": {"type": "boolean", "default": false},
            "authorised_reseller": {"type": "boolean", "default": false},
            "grey_import": {"type": "boolean", "default": false},
            "fraud_suspect": {"type": "boolean", "default": false}
          },
          "additionalProperties": false
        }
      }
    }
  },
  "vendors": [
